# ============================================================================
# Sehat-e-Aam configuration. Copy to .env and fill in your values.
# ============================================================================

# --- LLM backend selection -------------------------------------------------
# Options:
#   "databricks"  -> Databricks Foundation Model API (uses databricks-sdk auth)
#   "openai"      -> Any OpenAI-compatible endpoint (Together, Ollama, OpenAI, Groq, ...)
LLM_BACKEND=openai

# --- Databricks (when LLM_BACKEND=databricks) -----------------------------
# DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...
# LLM_MODEL=databricks-meta-llama-3-1-70b-instruct
# EMBEDDING_MODEL=databricks-gte-large-en

# --- OpenAI-compatible (when LLM_BACKEND=openai) --------------------------
# Local: Ollama  -> OPENAI_BASE_URL=http://localhost:11434/v1   LLM_MODEL=llama3.1:8b
# Together AI    -> OPENAI_BASE_URL=https://api.together.xyz/v1 LLM_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
# Groq           -> OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OpenAI         -> OPENAI_BASE_URL=https://api.openai.com/v1   LLM_MODEL=gpt-4o-mini
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
LLM_MODEL=llama3.1:8b

# --- Embedding backend -----------------------------------------------------
# "local"      -> use sentence-transformers locally (default, no key needed)
# "openai"     -> use OPENAI_BASE_URL above for embeddings
# "databricks" -> uses EMBEDDING_MODEL on Databricks Foundation Model API
EMBEDDING_BACKEND=local
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Pipeline knobs --------------------------------------------------------
EXTRACT_BATCH_SIZE=50
EXTRACT_MAX_WORKERS=4
EXTRACT_MAX_TOKENS=2048
EXTRACT_TEMPERATURE=0.0
EXTRACT_SAMPLE_LIMIT=0          # 0 = process all rows; set e.g. 200 to smoke test

CORRECTION_TRIGGER_TRUST=0.65   # only run self-correction below this score
CORRECTION_MAX_ITERATIONS=2
CORRECTION_SAMPLE_LIMIT=500

VECTOR_TOP_K=20
REASONING_TOP_K=5
MIN_TRUST_FOR_REASONING=0.4
DESERT_HIGH_RISK_THRESHOLD=0.70

# --- Paths ----------------------------------------------------------------
DATA_DIR=./data
LAKEHOUSE_DIR=./lakehouse
VECTOR_INDEX_DIR=./vector_index
MLFLOW_TRACKING_URI=./mlruns

RAW_DATASET_PATH=./data/facilities.csv
